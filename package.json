{
  "name": "soft-focus",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "smoke:test": "node --import tsx tests/fullFlowSmoke.ts && node --import tsx tests/sessionPersistence.ts && node --import tsx tests/sessionRestartLifecycle.ts && node --import tsx tests/sessionPanelActions.ts",
    "build": "bun run typecheck && vite build",
    "validate": "bun run typecheck && bun run smoke:test && vite build",
    "preview": "vite preview",
    "e2e:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers npx playwright install chromium",
    "e2e:test": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers npx playwright test"
  },
  "dependencies": {
    "phaser": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
